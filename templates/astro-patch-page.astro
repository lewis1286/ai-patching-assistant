---
/**
 * ASTRO PATCH PAGE TEMPLATE
 * =========================
 * Adapt this to match your site's layout and viz page conventions.
 *
 * Two integration options:
 *
 * OPTION A — Iframe embed (simplest):
 *   Copy the .html patch file into your site's public/ directory, then
 *   embed it via <iframe>. Zero parsing required.
 *
 * OPTION B — Native Astro page (recommended for full site integration):
 *   Copy the PATCH data object out of the .html file into a .json file,
 *   then import it here and pass to a client-side island component.
 *
 * This file shows Option B. Adjust the Layout import and any wrappers
 * to match your existing viz page structure.
 */

// If using a content collection (recommended):
import { getCollection, getEntry } from 'astro:content';

// Adapt to your site's layout component
import Layout from '../../layouts/Layout.astro';

// Static path generation — one page per patch JSON file
export async function getStaticPaths() {
  const patches = await getCollection('patches');
  return patches.map(patch => ({
    params: { slug: patch.slug },
    props:  { patch },
  }));
}

const { patch } = Astro.props;
const { data } = patch;
---

<Layout title={`${data.title} — Eurorack Patches`}>
  <article class="patch-page">
    <header class="patch-hero">
      <div class="patch-hero-inner">
        <div class="patch-breadcrumb">
          <a href="/patches">Patches</a>
          <span>›</span>
          <span>{data.category}</span>
        </div>
        <h1>{data.title}</h1>
        <div class="patch-chips">
          <span class="chip">{data.category}</span>
          <span class="chip">{data.complexity}</span>
          <span class="chip">{data.voices}</span>
          <span class="chip date">{data.date}</span>
        </div>
      </div>
    </header>

    <!-- Interactive patch viewer — client:only so SVG animations work -->
    <!-- Replace PatchViewer with your own component, or use the iframe approach below -->
    <!--
    <PatchViewer client:only="vanilla" patch={data} />
    -->

    <!-- OPTION A: iframe embed (uncomment if not using a component) -->
    <!--
    <div class="patch-iframe-wrapper">
      <iframe
        src={`/patches/${patch.slug}.html`}
        title={data.title}
        width="100%"
        style="border:none; min-height:600px;"
        loading="lazy"
      />
    </div>
    -->

    {data.concept && (
      <div class="patch-concept">
        <p>{data.concept}</p>
      </div>
    )}
  </article>
</Layout>

<style>
  .patch-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
  }

  .patch-hero {
    padding: 2.5rem 0 1.5rem;
  }

  .patch-breadcrumb {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.75rem;
  }

  .patch-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .patch-breadcrumb a:hover { color: #333; }

  h1 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    color: #111;
  }

  .patch-chips {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .chip {
    padding: 0.2rem 0.65rem;
    background: #f0f0f0;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    color: #555;
  }

  .chip.date { color: #999; }

  .patch-concept {
    padding: 1rem 1.25rem;
    background: #fafafa;
    border-left: 3px solid #ddd;
    border-radius: 0 6px 6px 0;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: #444;
    line-height: 1.6;
  }

  .patch-iframe-wrapper {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
</style>
